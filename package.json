{
  "name": "@qfactory/bridge",
  "version": "0.2.0",
  "description": "Bridge — run agent tasks on your own machine through your own CLI (Claude Code / Codex / Cursor / Gemini). MCP server + `qf` CLI.",
  "license": "MIT",
  "author": "Oleg Kukharuk",
  "type": "module",
  "main": "./dist/core/index.js",
  "types": "./dist/core/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    }
  },
  "bin": {
    "qf-mcp": "./dist/mcp/index.js",
    "qf": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "tsx test/run.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "agent",
    "cli",
    "mcp",
    "claude-code",
    "codex",
    "daemon",
    "bridge"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "commander": "^14.0.0",
    "zod": "^3.25.30"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsup": "^8.5.0",
    "tsx": "^4.19.2",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0leg-design/qfactory-bridge.git"
  },
  "homepage": "https://github.com/0leg-design/qfactory-bridge#readme",
  "bugs": {
    "url": "https://github.com/0leg-design/qfactory-bridge/issues"
  }
}
