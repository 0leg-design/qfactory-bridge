{
  "name": "@q-factory/bridge",
  "version": "0.1.0",
  "description": "Q-Factory local bridge — MCP server for Claude Code + CLI for Codex/scripts",
  "license": "MIT",
  "type": "module",
  "main": "./dist/core/index.js",
  "types": "./dist/core/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    }
  },
  "bin": {
    "qf-mcp": "./dist/mcp/index.js",
    "qf": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "commander": "^14.0.0",
    "zod": "^3.25.30"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsup": "^8.5.0",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=20"
  }
}
